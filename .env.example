# SandboxPulse 配置模板:复制为 .env 后填写(cp .env.example .env)
# .env 是个人/敏感配置,不要提交到 git

# hermes 通知目标(微信 target ID);留空则不发送通知
SANDBOXPULSE_HERMES_TARGET=

# 两条通知的最小间隔,单位秒(iLink 限频约 1 条/分钟,可按需调大)
SANDBOXPULSE_HERMES_MIN_INTERVAL_S=10

# 通知合并防抖窗口,单位秒;0 表示不防抖
SANDBOXPULSE_HERMES_DEBOUNCE_S=0

# 监听入站消息的网关日志,用于"收到新消息时立即冲刷通知队列";留空禁用该触发
SANDBOXPULSE_HERMES_PULL_LOG=~/.hermes/logs/gateway.log

# 日志级别:DEBUG / INFO / WARNING / ERROR
SANDBOXPULSE_LOG_LEVEL=INFO
